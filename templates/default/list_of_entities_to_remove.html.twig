{% extends 'base.html.twig' %}

{% block page_title %}
  <title>Remove Entities</title>
{% endblock %}

{% block content %}
  <div class="container mb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start">
      {% include 'default/_admin-sidebar-menu.html.twig' %}
      <div class="col-12 col-md-9">
        <div class="page-header">
          <h1>Choose a {{ displayName }} to REMOVE</h1>
        </div>
        <ul>
          {% for entity in entities %}
            {% if entityName == 'Dataset' %}
              <li class="entities-list-item">
                <a href="/remove/Dataset/{{ entity.getDatasetUid }}">{{ entity.getDisplayName }}</a>
              </li>
            {% else %}
              <li class="entities-list-item">
                <a href="/remove/{{ entityName }}/{{ entity.slug }}">{{ entity.getDisplayName }}</a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
{% endblock %}
