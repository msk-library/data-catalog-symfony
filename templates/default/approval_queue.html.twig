{% extends 'base.html.twig' %}

{% block page_title %}
  <title>Unpublished Datasets</title>
{% endblock %}

{% block content %}
  <div class="container mb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-start">
      {% include 'default/_admin-sidebar-menu.html.twig' %}
      <div class="col-12 col-md-9">
        <div class="page-header">
          <h1>Unpublished Datasets</h1>
        </div>

        <ul>
          {% for item in approvalQueue %}
            <li>
              <a href="{{ path('update_dataset', { uid: item.datasetUid }) }}">{{ item.getDisplayName }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
{% endblock %}
